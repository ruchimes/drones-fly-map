# URL del backend desplegado en Render.
# Copia este fichero como .env.production.local y rellena el valor real
# ANTES de hacer el build para Vercel, o configúralo como variable de entorno
# en el dashboard de Vercel (Settings → Environment Variables).
#
# Ejemplo: REACT_APP_API_URL=https://drones-app-backend.onrender.com

REACT_APP_API_URL=
