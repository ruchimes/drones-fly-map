3.6942338859998927,40.417447440000046],[-3.6942420409999386,40.417442657000038],[-3.694250709999892,40.417438436000054],[-3.6942598269998825,40.417434808000053],[-3.6942693239999471,40.417431802000067],[-3.6942791269999589,40.417429439000045],[-3.6942891619999045,40.417427739000061],[-3.6942993529999058,40.417426714000044]]]}},{"attributes":{"identifier":"INF0224","country":"ESP","regulationExemption":"SI","type":"CONDITIONAL","name":null,"reasons":"OTHER","message":"Se encuentra en una \u003cb\u003eZona Geográfica de UAS \u003c/b\u003ede protección de las infraestructuras ferroviarias, gestionada por \u003cb\u003eADIF/ ADIF AV\u003c/b\u003e.\u003cp\u003e\u003cfont color=\"#dc143c\"\u003e\u003cb\u003eCategoría Abierta:\u003c/b\u003e\u003c/font\u003e Toda la zona es una Zona Geográfica Particular, que afecta a los vuelos en categoría abierta. \u003cb\u003eCompruebe, para vuelos por debajo de 120m\u003c/b\u003e respecto al suelo, si su operación está en zona declarativa o requiere autorización previa de \u003cb\u003eADIF/ ADIF AV\u003c/b\u003e y conozca las condiciones de vuelo en la web \u003cfont color=\"#009fda\"\u003e\u003ca href='https://www.adif.es/solicitud-de-actuaciones-en-zona-de-afeccion-del-ferrocarril'  target='_blank'\u003eADIF\u003c/a\u003e\u003c/font\u003e. No se requiere aprobación por \u003cfont color=\"#009fda\"\u003e\u003ca href='https://www.seguridadaerea.gob.es/es/ambitos/drones/operaciones-con-uas-drones/operaciones-con-uas-drones---categoria-abierta-subcategorias-a1-a2-y-a3' target='_blank'\u003eAESA\u003c/a\u003e\u003c/font\u003e.\u003c/p\u003e\u003cp\u003eEn las zonas donde el ferrocarril discurra en túnel, sólo se debe tener en cuenta aquellas instalaciones asociadas al túnel que pudiesen estar en la vertical de la traza representada, a la hora de realizar las operaciones.\u003c/p\u003e\u003cp\u003e\u003cfont color=\"#dc143c\"\u003e\u003cb\u003eCategoría Específica:\u003c/b\u003e\u003c/font\u003e Zona Geográfica General, de menores dimensiones que la particular. La zona horizontalmente se extenderá 25m medidos desde los extremos exteriores de sus laterales en infraestructuras lineales y 10m en las no lineales. Verticalmente, a una \u003cb\u003ealtura mínima de 50m sobre el punto más elevado\u003c/b\u003e de la infraestructura o instalación afectada. Se requiere permiso del titular \u003cfont color=\"#009fda\"\u003e\u003ca href='https://www.adif.es/solicitud-de-actuaciones-en-zona-de-afeccion-del-ferrocarril'  target='_blank'\u003eADIF\u003c/a\u003e\u003c/font\u003e.\u003c/p\u003e","variant":"CUSTOMIZED","otherReasonInfo":"Protección Infraestructura Ferroviaria","restrictionConditions":null,"region":null,"extendedProperties":null,"issued":null,"validFrom":null,"validTo":null,"provider":"ADIF","description":null,"otherGeoid":null,"technicalLimitation":null,"originator":"","purpose":"NOTIFICATION","intervalBefore":"P20D","service":null,"contactName":"","siteURL":"https://www.adif.es/solicitud-de-actuaciones-en-zona-de-afeccion-del-ferrocarril","email":"autorizacioneszonadeafeccion@adif.es","phone":null,"lower":0.0,"lowerReference":"AGL","upper":120.0,"upperReference":"AGL","uom":"M","creationDateTime":"","updateDateTime":"2026-01-29T14:54:47","startDateTime":"","endDateTime":"","day":"ANY","startTime":"","startEvent":"","endTime":"","endEvent":"","name_authority":"ADIF","GFID":"{03C21E39-E47C-46DD-8741-9B23882428FE}","OBJECTID":12822,"SHAPE.STArea()":5.4146787558456011e-05,"SHAPE.STLength()":0.053247589254884917},"geometry":{"rings":[[[-3.7153765729999577,40.403072995000059],[-3.7156741209998927,40.403205333000074],[-3.7159557709999262,40.403356644000041],[-3.7162194619999127,40.403525818000048],[-3.716463256999873,40.403711613000041],[-3.7166853719999153,40.403912670000068],[-3.7168841779998729,40.404127513000049],[-3.7170582159999412,40.404354569000077],[-3.7172062109999615,40.404592173000026],[-3.7173270799999045,40.404838584000061],[-3.7173432279998906,40.404879633000064],[-3.7193176489998905,40.41036